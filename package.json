    "@types/ws": "^8",
    "@typescript/native-preview": "7.0.0-dev.20260512.1",
    "@vitest/coverage-v8": "^4",
    "@vitest/ui": "^4",
    "bun-types": "^1",
    "drizzle-kit": "^0.31",
    "happy-dom": "^20",
    "openapi-typescript": "^7.13.0",
    "swr": "^2.4.2",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4"
  }
}
